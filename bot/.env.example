# AI Child Bot Configuration - EXAMPLE TEMPLATE
# Copy this file to .env and fill in your values
# ⚠️  IMPORTANT: Never commit .env to version control!

# ── AI Child Server ────────────────────────────────────────────────────
SERVER_URL=http://localhost:8000

# ── Telegram Configuration ─────────────────────────────────────────────
# Get your token from @BotFather on Telegram
# Leave empty to disable Telegram
# TELEGRAM_TOKEN=your-actual-telegram-bot-token-here

# ── QQ Configuration (go-cqhttp) ───────────────────────────────────────
# HTTP API URL of go-cqhttp (usually http://localhost:5700)
# Setup: https://github.com/Mrs4s/go-cqhttp
QQ_API_URL=http://localhost:5700

# Optional authentication token for QQ API
# QQ_API_TOKEN=your-optional-token-here

# ── Polling Settings ───────────────────────────────────────────────────
# How often (in seconds) to poll the server for new proactive questions
QUESTION_POLL_INTERVAL=60

# ── Webhook Receiver ───────────────────────────────────────────────────
# Port for the webhook HTTP server
WEBHOOK_PORT=8001

# Optional secret token required in incoming webhook requests
# WEBHOOK_SECRET=your-optional-secret-key-here
