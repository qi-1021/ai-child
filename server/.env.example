# AI Child Server Configuration - EXAMPLE TEMPLATE
# Copy this file to .env and fill in your values
# ⚠️  IMPORTANT: Never commit .env to version control!

# ── LLM Provider Selection ──────────────────────────────────────────────
# Options: "openai", "dashscope" (阿里云百炼), or "ollama" (local, recommended)
LLM_PROVIDER=ollama

# ── OpenAI Configuration (if using openai provider) ─────────────────────
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-actual-api-key-here
# OPENAI_MODEL=gpt-4
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── DashScope Configuration (if using dashscope provider) ───────────────
# Enable for 阿里云百炼 (China region) - Requires API key
# Get key from: https://dashscope.aliyuncs.com/
# DASHSCOPE_API_KEY=sk-your-actual-dashscope-key-here
# DASHSCOPE_MODEL=qwen3.5-35b-a3b
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Ollama Configuration (if using ollama provider) ────────────────────
# Local LLM deployment - no API key needed!
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2  # or other Ollama models

# ── Server Settings ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production

# ── Sleep/Wake Cycle ───────────────────────────────────────────────────
SLEEP_ENABLED=true
SLEEP_HOUR=22
WAKE_HOUR=7
AI_TIMEZONE=Asia/Shanghai

# ── Social Learning (RSS feeds) ────────────────────────────────────────
SOCIAL_LEARNING_ENABLED=true
RSS_POLL_INTERVAL_MINUTES=60
RSS_SUMMARISE_ENABLED=true

# ── Research Settings ──────────────────────────────────────────────────
RESEARCH_ENABLED=true
RESEARCH_QUERY_COUNT=3
RESEARCH_MAX_RESULTS=4
